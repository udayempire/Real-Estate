// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id                 String   @id @default(cuid())
  firstName          String?
  lastName           String?
  email              String   @unique
  passwordHash       String
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive])
  @@map("super_admins")
}

enum StaffRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
  CUSTOMER_SUPPORT
}

model Staff {
  id                          String                       @id @default(cuid())
  firstName                   String
  lastName                    String
  age                         Int?
  gender                      Gender?
  phone                       String?                      @unique
  email                       String                       @unique
  passwordHash                String?
  role                        StaffRole
  twoFactorSecret             String?
  isTwoFactorEnabled          Boolean                      @default(false)
  isActive                    Boolean                      @default(true)
  isBlocked                   Boolean                      @default(false)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  requestedGemRequests        GemRequest[]                 @relation("GemRequestedBy")
  reviewedGemRequests         GemRequest[]                 @relation("GemReviewedBy")
  gemTransactions             GemTransaction[]             @relation("GemTransactionCreatedBy")
  staffPropertyBookmarks      StaffPropertyBookmark[]
  propertyAcquisitionRequests PropertyAcquisitionRequest[] @relation("PropertyAcquisitionRequest")
  banRequests                 BanRequest[]                 @relation("BanRequestedBy")
  appointments                Appointment[]                
  @@index([role])
  @@index([isActive])
  @@index([email])
  @@map("staff")
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String    @unique
  phone        String    @unique
  password     String
  avatar       String?
  avatarKey    String?
  age          Int?
  gender       Gender?
  isBlocked    Boolean   @default(false)
  referralCode String    @unique
  referrerId   String?
  referrer     User?     @relation("Referrals", references: [id], fields: [referrerId])
  referrals    User[]    @relation("Referrals") //users referred by User. 
  points       Int       @default(0) //rename to gems later
  blockedBy    String?
  blockedOn    DateTime?

  //verification
  isEmailVerified  Boolean @default(false)
  blueTick    Boolean @default(false) //blue tick
  isVerifiedSeller Boolean @default(false) //green tick

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  kyc                   Kyc[]
  properties            Property[]
  otps                  Otp[]
  refreshTokens         RefreshToken[]
  supportTickets        CustomerSupport[]
  savedProperties          SavedProperty[]
  savedExclusiveProperties SavedExclusiveProperty[]
  appointments             Appointment[]
  gemTransactions          GemTransaction[]
  gemRequestsAsTarget      GemRequest[]        @relation("GemRequestTargetUser")
  gemRequestsAsReferral    GemRequest[]        @relation("GemRequestReferralUser")
  exclusiveProperties      ExclusiveProperty[] @relation("ExclusiveOriginalUser")
  banRequests              BanRequest[]        @relation("BanRequestTargetUser")
  notifications            UserNotification[]
  deviceTokens             UserDeviceToken[]
  propertyRequirements     PropertyRequirement[]

  @@index([id, email])
  @@map("users")
}

enum NotificationType {
  GENERIC
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  APPOINTMENT_CANCELLED
  SUPPORT_TICKET_CREATED
  SUPPORT_TICKET_UPDATED
  EXCLUSIVE_PROPERTY_ADDED
  USER_VERIFIED
  BLUE_TICK_EARNED
  USER_PROFILE_UPDATED
  AADHAR_REJECTION
  PAN_REJECTION
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

model UserNotification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType @default(GENERIC)
  title       String
  description String           @db.Text
  data        Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@index([type])
  @@map("user_notifications")
}

model UserDeviceToken {
  id         String         @id @default(cuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform
  isActive   Boolean        @default(true)
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId, isActive])
  @@map("user_device_tokens")
}

enum BanRequestStatus {
  PENDING_SUPERADMIN
  APPROVED
  REJECTED
}

model BanRequest {
  id              String           @id @default(cuid())
  userId          String
  status          BanRequestStatus @default(PENDING_SUPERADMIN)
  banReqByStaffId String
  banReqByStaff   Staff            @relation("BanRequestedBy", fields: [banReqByStaffId], references: [id])
  user            User             @relation("BanRequestTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([userId])
  @@index([banReqByStaffId])
  @@map("ban_requests")
}

enum PropertyStatus {
  ACTIVE
  UNLISTED
  SOLDOFFLINE
  SOLDTOREALBRO
  SOLDFROMLISTINGS
  DRAFT
  SOLDEXCLUSIVEPROPERTY //property is sold from exclusive property
  PENDING_EXCLUSIVE_ACQUISITION
}

enum SizeUnit {
  ACRES
  UNITS
  SQFT
  SQMT
}

enum Category {
  RESIDENTIAL
  COMMERCIAL
  AGRICULTURAL
}
  
enum FurnishingStatus {
  FullyFurnished
  SemiFurnished
  Unfurnished
  FencedWired
  FertileLand
  OpenLand
  Cultivated
}

enum AvailabilityStatus {
  ReadyToMove
  UnderConstruction
}

enum AgeOfProperty {
  ZeroToOne
  OneToThree
  ThreeToSix
  SixToTen
  TenPlus
}

enum CarpetAreaUnit {
  SQFT
  SQM
  ACRES
}

enum PropertyFacing {
  East
  West
  North
  South
  NorthEast
  NorthWest
  SouthEast
  SouthWest
}

model Property {
  id           String         @id @default(cuid())
  title        String
  description  String?
  propertyType String?
  status       PropertyStatus @default(ACTIVE)

  // Price - Updated
  listingPrice Float?
  priceMin     Float? // Deprecated but kept for backward compatibility
  priceMax     Float? // Deprecated but kept for backward compatibility

  // Location
  state       String?
  city        String?
  locality    String? // Main locality (e.g., "Arera Colony")
  subLocality String? // Society/Building name
  flatNo      String? // Flat/House number
  area        String? // Keep for backward compatibility
  address     String?
  latitude    Float?
  longitude   Float?

  // Size - Updated
  carpetArea       Float?
  carpetAreaUnit   CarpetAreaUnit?
  plotLandArea     Float?
  plotLandAreaUnit CarpetAreaUnit?
  size             Float? // Deprecated but kept for backward compatibility
  sizeUnit         SizeUnit? // Deprecated but kept for backward compatibility

  // Basic Details - New
  category           Category?
  furnishingStatus   FurnishingStatus?
  availabilityStatus AvailabilityStatus?
  ageOfProperty      AgeOfProperty?

  // Property Details - New
  numberOfRooms     Int?
  numberOfBathrooms Int?
  numberOfBalcony   Int?
  numberOfFloors    Int?
  propertyFloor     String?

  // Price Details - New
  allInclusivePrice      Boolean @default(false)
  negotiablePrice        Boolean @default(false)
  govtChargesTaxIncluded Boolean @default(false)

  // Other Details - New
  propertyFacing     PropertyFacing?
  amenities          String[] // Array of amenities
  locationAdvantages String[] // Array of location advantages
  coveredParking     Int             @default(0)
  uncoveredParking   Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //Relations
  userId                 String
  user                   User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  media                  PropertyMedia[]
  savedBy                SavedProperty[]
  appointments           Appointment[]
  gemRequests            GemRequest[]                 @relation("GemRequestTargetProperty")
  exclusiveProperty      ExclusiveProperty?           @relation("ExclusiveSourceProperty")
  staffPropertyBookmarks StaffPropertyBookmark[]
  acquisitionRequests    PropertyAcquisitionRequest[] @relation("PropertyAcquisitionRequest")

  @@index([userId])
  @@index([propertyType])
  @@index([status])
  @@index([state, city])
  @@index([listingPrice])
  @@map("properties")
}

// property media

enum MediaType {
  IMAGE
  VIDEO
}

model PropertyMedia {
  id        String    @id @default(cuid())
  url       String
  key       String // s3 key for deletion
  mediaType MediaType
  order     Int       @default(0) // for ordering photos
  createdAt DateTime  @default(now())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_media")
}

enum ExclusivePropertyStatus {
  ACTIVE
  SOLD_OUT
  UNLISTED
}

model ExclusiveProperty {
  id String @id @default(cuid())

  // Link to original normal property (for trace/audit)
  sourcePropertyId String   @unique
  sourceProperty   Property @relation("ExclusiveSourceProperty", fields: [sourcePropertyId], references: [id], onDelete: Restrict)

  // Copy of all property fields
  title        String
  description  String?
  propertyType String?
  status       ExclusivePropertyStatus @default(ACTIVE)

  // Price
  listingPrice Float?
  priceMin     Float?
  priceMax     Float?

  // Location
  state       String?
  city        String?
  locality    String?
  subLocality String?
  flatNo      String?
  area        String?
  address     String?
  latitude    Float?
  longitude   Float?

  // Size
  carpetArea       Float?
  carpetAreaUnit   CarpetAreaUnit?
  plotLandArea     Float?
  plotLandAreaUnit CarpetAreaUnit?
  size             Float?
  sizeUnit         SizeUnit?

  // Basic details
  category           Category?
  furnishingStatus   FurnishingStatus?
  availabilityStatus AvailabilityStatus?
  ageOfProperty      AgeOfProperty?

  // Property details
  numberOfRooms     Int?
  numberOfBathrooms Int?
  numberOfBalcony   Int?
  numberOfFloors    Int?
  propertyFloor     String?

  // Price flags
  allInclusivePrice      Boolean @default(false)
  negotiablePrice        Boolean @default(false)
  govtChargesTaxIncluded Boolean @default(false)

  // Other details
  propertyFacing     PropertyFacing?
  amenities          String[]
  locationAdvantages String[]
  coveredParking     Int             @default(0)
  uncoveredParking   Int             @default(0)

  // Exclusive-specific
  fixedRewardGems Int
  migratedAt      DateTime  @default(now())
  soldOutAt       DateTime?
  notes           String?

  // Keep owner reference
  originalUserId String
  originalUser   User   @relation("ExclusiveOriginalUser", fields: [originalUserId], references: [id], onDelete: Restrict)

  // Relations
  media   ExclusivePropertyMedia[]
  savedBy SavedExclusiveProperty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([city, state])
  @@index([listingPrice])
  @@index([originalUserId])
  @@map("exclusive_properties")
}

model ExclusivePropertyMedia {
  id                  String            @id @default(cuid())
  exclusivePropertyId String
  exclusiveProperty   ExclusiveProperty @relation(fields: [exclusivePropertyId], references: [id], onDelete: Cascade)

  url       String
  key       String
  mediaType MediaType
  order     Int       @default(0)

  createdAt DateTime @default(now())

  @@index([exclusivePropertyId])
  @@map("exclusive_property_media")
}

model StaffPropertyBookmark {
  id         String   @id @default(cuid())
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([staffId, propertyId])
  @@index([staffId])
  @@index([propertyId])
  @@map("staff_property_bookmarks")
}

enum PropertyAcquisitionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PropertyAcquisitionRequest {
  id                 String                           @id @default(cuid())
  propertyId         String                           @unique
  requestedByStaffId String
  status             PropertyAcquisitionRequestStatus @default(PENDING)
  property           Property                         @relation("PropertyAcquisitionRequest", fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt
  requestedByStaff   Staff                            @relation("PropertyAcquisitionRequest", fields: [requestedByStaffId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

enum KycType {
  AADHARCARD
  PANCARD
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Kyc {
  id              String    @id @default(cuid())
  type            KycType
  status          KycStatus @default(PENDING)
  docNo           String
  imageUrl        String
  imageKey        String
  rejectionReason String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@index([status])
  @@map("kyc")
}

//AUTH

enum OtpType {
  EMAIL
  PHONE
  RESET_PASSWORD
  GEM_TXN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Otp {
  id        String   @id @default(cuid())
  code      String
  type      OtpType
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("otps")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PendingSignup {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String   @unique
  phone            String   @unique
  passwordHash     String
  age              Int
  gender           Gender
  avatar           String?
  avatarKey        String?
  referrerDbUserId String

  aadharNo         String
  kycAadharImageUrl String
  kycAadharImageKey String
  panNo            String
  kycPanImageUrl   String
  kycPanImageKey   String

  otpCode          String
  otpExpiresAt     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@map("pending_signups")
}

// Customer Support

enum TicketStatus {
  OPEN
  CLOSED
}

model CustomerSupport {
  id               String       @id @default(cuid())
  name             String
  phoneNo          String
  description      String       @db.Text
  isRequestForCall Boolean      @default(false)
  ticketStatus     TicketStatus @default(OPEN)

  // User info
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([ticketStatus])
  @@map("customer_support")
}

// Saved Exclusive Properties (User wishlist/bookmarks for exclusive properties)

model SavedExclusiveProperty {
  id                  String            @id @default(cuid())
  userId              String
  exclusivePropertyId String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exclusiveProperty   ExclusiveProperty @relation(fields: [exclusivePropertyId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())

  @@unique([userId, exclusivePropertyId])
  @@index([userId])
  @@index([exclusivePropertyId])
  @@map("saved_exclusive_properties")
}

// Saved Properties (User wishlist/bookmarks)

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId]) // Prevent duplicate saves
  @@index([userId])
  @@index([propertyId])
  @@map("saved_properties")
}

// Appointments (Property viewing appointments)

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  WAITING 
}

model Appointment {
  id              String            @id @default(cuid())
  userId          String
  propertyId      String
  appointmentDate DateTime
  appointmentTime String // Stored as string (e.g., "10:00 AM", "14:30")
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?           @db.Text
  isPreBooked     Boolean           @default(false) // Whether user has pre-booked this appointment
  staffHandlerId  String?
  staffHandler    Staff?            @relation(fields: [staffHandlerId], references: [id], onDelete: SetNull)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@index([appointmentDate])
  @@index([status])
  @@map("appointments")
}

enum GemRequestType {
  EXCLUSIVE_ACQUISITION_REWARD
  EXCLUSIVE_SALE_REWARD
  REDEMPTION
}

enum GemRequestStatus {
  DRAFT
  PENDING_SUPERADMIN
  APPROVED
  REJECTED
  CANCELLED
}

enum GemTxnType {
  CREDIT
  DEBIT
}

enum GemTxnReason {
  ACQUISITION_REWARD
  EXCLUSIVE_SALE_REWARD
  REFERRAL_BONUS_5_PERCENT
  REDEMPTION
  GEM_REDEEM
}

model GemRequest {
  id                 String           @id @default(cuid())
  type               GemRequestType
  status             GemRequestStatus @default(DRAFT)
  // who initiated and who approved/rejected
  requestedByStaffId String
  reviewedByStaffId  String?
  requestedByStaff   Staff            @relation("GemRequestedBy", fields: [requestedByStaffId], references: [id])
  reviewedByStaff    Staff?           @relation("GemReviewedBy", fields: [reviewedByStaffId], references: [id])

  // target user and optional referral beneficiary
  userId         String
  user           User    @relation("GemRequestTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  referralUserId String?
  referralUser   User?   @relation("GemRequestReferralUser", fields: [referralUserId], references: [id], onDelete: SetNull)

  // optional property context
  propertyId String?
  property   Property? @relation("GemRequestTargetProperty", fields: [propertyId], references: [id], onDelete: SetNull)

  // values snapshot at request time
  baseGems          Int
  referralPercent   Float   @default(5.0)
  referralGems      Int     @default(0)
  totalGems         Int     @default(0)
  // for redemption
  redemptionEtaDays Int?
  failureReason     String?
  comment           String?

  // OTP proof (store hash if you want stronger audit)
  otpVerifiedAt        DateTime?
  otpVerifiedByStaffId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions GemTransaction[]

  @@index([status, type])
  @@index([userId, createdAt])
  @@index([propertyId])
  @@map("gem_requests")
}

model GemTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestId String
  request   GemRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  txnType       GemTxnType
  reason        GemTxnReason
  amount        Int
  balanceBefore Int
  balanceAfter  Int

  createdByStaffId String?
  createdByStaff   Staff?  @relation("GemTransactionCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([requestId])
  @@map("gem_transactions")
}

enum PropertyRequirementStatus {
  ACTIVE
  FULFILLED
  CLOSED
}

model PropertyRequirement {
  id                String                    @id @default(cuid())
  preferredLocation String
  subLocation       String?
  propertyType      String?
  budgetMin         Float?
  budgetMax         Float?
  currency          String                    @default("INR")
  status            PropertyRequirementStatus @default(ACTIVE)
  userId            String
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("property_requirements")
}

model Banner{
  id String @id @default(cuid())
  title String?
  image String
  imageKey String
  status BannerStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([status])
  @@map("banners")
}

enum BannerStatus {
  INACTIVE
  ACTIVE
}